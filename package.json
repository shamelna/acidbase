{
  "homepage": "https://acidbase.kaizenmadeeasy.com",
  "name": "ab",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^5.12.0",
    "@testing-library/react": "^11.2.6",
    "@testing-library/user-event": "^12.8.3",
    "axios": "^0.21.1",
    "bulma": "^0.9.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-scripts": "^5.0.1",
    "web-vitals": "^1.1.1",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "npm run build && powershell -Command \"Copy-Item -Path build\\* -Destination . -Recurse -Force\" && git add . && git commit -m \"Deploy to GitHub Pages\" && git push",
    "deploy:check": "npm run build && npm run deploy",
    "deploy:status": "git log --oneline -n 5 && echo '=== Build files status ===' && dir | findstr /i \"index.html static\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "gh-pages": "^3.1.0"
  },
  "description": "A professional React-based web application for healthcare providers to analyze and interpret arterial blood gas (ABG) values and acid-base disorders.",
  "main": "excel-diagnosis-processor-xlsx.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamelna/acidbase.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/shamelna/acidbase/issues"
  }
}
