        <div class="batch-case-id">${r.caseID}</div>
        <div class="batch-case-diag">${res.diag}</div>
        <span class="batch-diag-badge ${getBadgeClass(res.cls)}">${res.cls==='normal'?'Normal':res.cls==='acidosis'?'Acidosis':res.cls==='alkalosis'?'Alkalosis':'—'}</span>
        <span class="batch-chevron">▶</span>
      </div>
      <div class="batch-case-body">
        <div class="batch-inputs-grid">${inTiles}</div>
        <div class="batch-diag-box ${res.cls}">
          <div class="batch-diag-primary">${res.diag}</div>
          ${res.ag?`<div class="batch-diag-ag">${res.ag}</div>`:''}
        </div>
        <ul class="batch-steps">${stepHtml}</ul>
      </div>
    </div>`;
  }).join('');
}

function toggleCase(i){
  document.getElementById('bc-'+i).classList.toggle('open');
}

// ── Excel export ──────────────────────────────────────────────
function exportBatchExcel(){
  const NAVY='FF12385B', BLUE='FF017BB5', RED='FFde1738', WHITE='FFFFFFFF', BG='FFe9f0f8', LBLUE='FFddeeff', LRED='FFfff0f2', LGREEN='FFf0fff5';
  const wb=XLSX.utils.book_new();

  // Summary sheet
  const sumRows=[['Acid-Base Batch Diagnosis Report'],['Generated: '+new Date().toLocaleDateString()],[''],
    ['Case ID','pH','PaCO₂','HCO₃','Na','Cl','Albumin','Primary Diagnosis','Anion Gap','Diagnosis Class']];
  batchResults.forEach(r=>{
    const res=r.result;
    sumRows.push([r.caseID,r.pH,r.paCO2,r.HCO3,r.Na||'',r.Cl||'',r.albumin||'',res.diag,res.ag||'',res.cls]);
  });
  const ws=XLSX.utils.aoa_to_sheet(sumRows);
  ws['!cols']=[{wch:14},{wch:8},{wch:9},{wch:8},{wch:8},{wch:8},{wch:10},{wch:50},{wch:38},{wch:12}];
  XLSX.utils.book_append_sheet(wb,ws,'Summary');

  // Individual detail sheet
  const detRows=[['Case ID','Step','Decision']];
  batchResults.forEach(r=>{
    r.result.steps.forEach((s,i)=>detRows.push([r.caseID,i+1,s.t]));
    detRows.push(['','','']);
  });
  const ws2=XLSX.utils.aoa_to_sheet(detRows);
  ws2['!cols']=[{wch:14},{wch:6},{wch:80}];
  XLSX.utils.book_append_sheet(wb,ws2,'Decision Paths');

  XLSX.writeFile(wb,'ABG_Batch_Results.xlsx');
}

// ── PDF export (jsPDF) ────────────────────────────────────────
function exportBatchPDF(){
  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({unit:'mm',format:'a4'});
  const W=210,M=14,CW=W-2*M;
  const NAVY=[18,56,91], BLUE=[1,123,181], RED=[222,23,56];
  const LRED=[255,240,242], LBLUE=[240,248,255], LGREEN=[240,255,245], LGRAY=[245,247,250];

  let y=0;

  function newPage(){
    doc.addPage();
    y=16;
    // Header stripe
    doc.setFillColor(...NAVY);
    doc.rect(0,0,W,10,'F');
    doc.setTextColor(255,255,255);
    doc.setFontSize(7);
    doc.setFont('helvetica','bold');
    doc.text('ACID-BASE BATCH DIAGNOSIS REPORT',M,6.5);
    doc.text('Page '+doc.getCurrentPageInfo().pageNumber,W-M,6.5,'right');
    y=16;
  }

  function checkY(need){
    if(y+need>280) newPage();
  }

  // Cover page
  doc.setFillColor(...NAVY);
  doc.rect(0,0,W,55,'F');
  doc.setFillColor(...BLUE);
  doc.rect(0,55,W,3,'F');

  doc.setTextColor(255,255,255);
  doc.setFont('helvetica','bold');
  doc.setFontSize(22);
  doc.text('Acid-Base Diagnosis',M,22);
  doc.setFontSize(13);
  doc.setFont('helvetica','normal');
  doc.text('Batch Analysis Report',M,32);
  doc.setFontSize(9);
  doc.text(`${batchResults.length} cases  ·  ${new Date().toLocaleDateString('en-AU',{day:'numeric',month:'long',year:'numeric'})}`,M,42);

  y=68;
  // Summary table header
  doc.setFillColor(...LGRAY);
  doc.rect(M,y,CW,8,'F');
  doc.setTextColor(...NAVY);
  doc.setFont('helvetica','bold');
  doc.setFontSize(9);
  const sumCols=[['#',8],['Case ID',28],['pH',14],['PaCO₂',16],['HCO₃',16],['Diagnosis',60],['Class',26]];
  let sx=M;
  sumCols.forEach(([h,w])=>{ doc.text(h,sx+2,y+5.2); sx+=w; });
  y+=8;

  const clsColor={acidosis:LRED,alkalosis:LBLUE,normal:LGREEN,neutral:LGRAY};
  const clsLabel={acidosis:'Acidosis',alkalosis:'Alkalosis',normal:'Normal',neutral:'—'};
  batchResults.forEach((r,i)=>{
    checkY(9);
    const bg=i%2===0?[255,255,255]:LGRAY;
    doc.setFillColor(...bg);
    doc.rect(M,y,CW,8,'F');
    const res=r.result;
    doc.setFont('helvetica','normal');
    doc.setFontSize(8.5);
    doc.setTextColor(14,42,66);
    const vals=[[(i+1).toString(),8],[r.caseID.toString().substring(0,14),28],[(+r.pH).toFixed(2),14],[(+r.paCO2).toFixed(1),16],[(+r.HCO3).toFixed(1),16],[res.diag.substring(0,38),60],[clsLabel[res.cls]||'—',26]];
    let vx=M;
    vals.forEach(([v,w])=>{ doc.text(v,vx+2,y+5.2); vx+=w; });
    y+=8;
  });

  // Individual case pages
  batchResults.forEach((r,i)=>{
    newPage();
    const res=r.result;
    const hBg=res.cls==='acidosis'?LRED:res.cls==='alkalosis'?LBLUE:res.cls==='normal'?LGREEN:LGRAY;
    const hBorder=res.cls==='acidosis'?RED:res.cls==='alkalosis'?BLUE:res.cls==='normal'?[26,122,58]:NAVY;

    // Case header
    doc.setFillColor(...hBg);
    doc.roundedRect(M,y,CW,14,2,2,'F');
    doc.setDrawColor(...hBorder);
    doc.setLineWidth(0.4);
    doc.roundedRect(M,y,CW,14,2,2,'S');
    doc.setFillColor(...hBorder);
    doc.rect(M,y,3,14,'F');
    doc.setTextColor(...NAVY);
    doc.setFont('helvetica','bold');
    doc.setFontSize(11);
    doc.text(`Case ${i+1}: ${r.caseID}`,M+6,y+5.5);
    doc.setFont('helvetica','normal');
    doc.setFontSize(8.5);
    doc.setTextColor(107,136,162);
    doc.text(`pH ${(+r.pH).toFixed(2)}  ·  PaCO₂ ${(+r.paCO2).toFixed(1)} mm Hg  ·  HCO₃ ${(+r.HCO3).toFixed(1)} mmol/L`,M+6,y+10.5);
    y+=18;

    // Diagnosis result
    doc.setFillColor(...NAVY);
    doc.rect(M,y,CW,8,'F');
    doc.setFill(255,255,255);
    doc.setTextColor(255,255,255);
    doc.setFont('helvetica','bold');
    doc.setFontSize(9);
    doc.text('Diagnosis',M+3,y+5.2);
    y+=8;
    doc.setFillColor(...hBg);
    doc.rect(M,y,CW,10,'F');
    doc.setTextColor(...NAVY);
    doc.setFont('helvetica','bold');
    doc.setFontSize(9.5);
    const diagLines=doc.splitTextToSize(res.diag,CW-6);
    doc.text(diagLines,M+3,y+5.5);
    y+=Math.max(10,diagLines.length*5)+2;
    if(res.ag){
      checkY(7);
      doc.setFillColor(240,248,220);
      doc.rect(M,y,CW,7,'F');
      doc.setFont('helvetica','normal');
      doc.setFontSize(8.5);
      doc.setTextColor(50,100,50);
      doc.text('Anion gap: '+res.ag,M+3,y+4.8);
      y+=9;
    }

    // Input values
    checkY(14);
    y+=3;
    doc.setFillColor(...LGRAY);
    doc.rect(M,y,CW,7,'F');
    doc.setTextColor(...NAVY);
    doc.setFont('helvetica','bold');
    doc.setFontSize(8);
    doc.text('Input values',M+3,y+4.8);
    y+=7;
    const fields=[['pH',(+r.pH).toFixed(2)],['PaCO₂',(+(r.paCO2||0)).toFixed(1)+' mm Hg'],['HCO₃',(+(r.HCO3||0)).toFixed(1)+' mmol/L'],['Na',(r.Na||'—')+''],['Cl',(r.Cl||'—')+''],['Albumin',(r.albumin||'—')+' g/L']];
    const tileW=CW/3, tileH=9;
    fields.forEach(([lbl,val],fi)=>{
      const tx=M+(fi%3)*tileW, ty=y+Math.floor(fi/3)*tileH;
      checkY(tileH);
      doc.setFillColor(255,255,255);
      doc.setDrawColor(...[218,225,235]);
      doc.setLineWidth(0.3);
      doc.rect(tx,ty,tileW-1,tileH,'FD');
      doc.setFont('helvetica','normal');
      doc.setFontSize(7);
      doc.setTextColor(107,136,162);
      doc.text(lbl,tx+2,ty+3.2);
      doc.setFont('helvetica','bold');
      doc.setFontSize(9);
      doc.setTextColor(...NAVY);
      doc.text(val,tx+2,ty+7.5);
    });
    y+=Math.ceil(fields.length/3)*tileH+5;

    // Decision path
    checkY(12);
    doc.setFillColor(...LGRAY);
    doc.rect(M,y,CW,7,'F');
    doc.setTextColor(...NAVY);
    doc.setFont('helvetica','bold');
    doc.setFontSize(8);
    doc.text('Decision path',M+3,y+4.8);
    y+=9;
    res.steps.forEach((s,si)=>{
      checkY(8);
      const dotClr=s.c==='red'?RED:s.c==='blue'?BLUE:s.c==='green'?[26,122,58]:s.c==='amber'?[186,117,23]:NAVY;
      doc.setFillColor(...dotClr);
      doc.circle(M+3,y+3,2,'F');
      doc.setTextColor(255,255,255);
      doc.setFont('helvetica','bold');
      doc.setFontSize(6);
      doc.text((si+1).toString(),M+3,y+3.8,'center');
      doc.setFont('helvetica','normal');
      doc.setFontSize(8);
      doc.setTextColor(14,42,66);
      const lines=doc.splitTextToSize(s.t,CW-10);
      doc.text(lines,M+8,y+4);
      y+=lines.length*4.5+2;
    });
  });

  doc.save('ABG_Batch_Results.pdf');
}

// Drag-and-drop
(function(){
  const dz=document.getElementById('drop-zone');
  if(!dz) return;
  dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('dragover')});
  dz.addEventListener('dragleave',()=>dz.classList.remove('dragover'));
  dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('dragover');const f=e.dataTransfer.files[0];if(f)handleFileImport(f);});
})();

