  el.style.display='block';
  el.style.background=type==='success'?'rgba(26,122,58,.1)':'rgba(222,23,56,.1)';
  el.style.border='1px solid '+(type==='success'?'rgba(26,122,58,.3)':'rgba(222,23,56,.3)');
  el.style.color=type==='success'?'#0f4a22':'#8b0f22';
  el.textContent=msg;
