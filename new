<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Acid-Base Analyser</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --navy:   #12385b;
  --blue:   #017bb5;
  --red:    #de1738;
  --bg:     #e9f0f8;
  --white:  #ffffff;
  --navy10: rgba(18,56,91,.08);
  --navy20: rgba(18,56,91,.15);
  --navy40: rgba(18,56,91,.35);
  --blue10: rgba(1,123,181,.10);
  --blue20: rgba(1,123,181,.20);
  --red10:  rgba(222,23,56,.10);
  --red20:  rgba(222,23,56,.20);
  --text:   #0e2a42;
  --muted:  #6b88a2;
  --border: rgba(18,56,91,.12);
  --r-sm: 6px;
  --r-md: 10px;
  --r-lg: 16px;
  --r-xl: 22px;
  --font: 'DM Sans', sans-serif;
  --mono: 'DM Mono', monospace;
  --shadow-sm: 0 1px 3px rgba(18,56,91,.08), 0 1px 2px rgba(18,56,91,.06);
  --shadow-md: 0 4px 12px rgba(18,56,91,.10), 0 2px 4px rgba(18,56,91,.07);
  --shadow-lg: 0 12px 32px rgba(18,56,91,.13), 0 4px 8px rgba(18,56,91,.08);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  font-size: 14px;
  line-height: 1.6;
  min-height: 100vh;
}

/* ─── Top bar ─────────────────────────────────────────────── */
.topbar {
  background: var(--navy);
  padding: 0 28px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}
.topbar-brand {
  display: flex;
  align-items: center;
  gap: 10px;
}
.topbar-logo {
  width: 32px;
  height: 32px;
  background: var(--blue);
  border-radius: var(--r-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}
.topbar-logo svg { display:block }
.topbar-title {
  font-size: 15px;
  font-weight: 600;
  color: #fff;
  letter-spacing: -.01em;
}
.topbar-sub {
  font-size: 11px;
  color: rgba(255,255,255,.5);
  letter-spacing: .04em;
  text-transform: uppercase;
}
.topbar-badge {
  font-size: 11px;
  color: rgba(255,255,255,.55);
  font-family: var(--mono);
  letter-spacing: .02em;
}

/* ─── Layout ──────────────────────────────────────────────── */
.layout {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 0;
  min-height: calc(100vh - 56px);
}

.sidebar {
  background: var(--white);
  border-right: 1px solid var(--border);
  padding: 24px 20px;
  overflow-y: auto;
}

.main {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* ─── Cards ───────────────────────────────────────────────── */
.card {
  background: var(--white);
  border-radius: var(--r-xl);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  padding: 20px 22px;
}
.card-title {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.card-title-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--blue);
  display: inline-block;
}

/* ─── Section labels (sidebar) ────────────────────────────── */
.section-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
  margin: 20px 0 10px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}
.section-label:first-child { margin-top: 0 }

/* ─── Sliders ─────────────────────────────────────────────── */
.slider-row {
  margin-bottom: 14px;
}
.slider-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 5px;
}
.slider-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
}
.slider-unit {
  font-size: 11px;
  color: var(--muted);
  margin-left: 3px;
}
.slider-value {
  font-family: var(--mono);
  font-size: 14px;
  font-weight: 500;
  color: var(--navy);
  min-width: 48px;
  text-align: right;
  transition: color .15s;
}
.slider-value.out { color: var(--red) }
.slider-value.in  { color: #1a7a3a }

.slider-track {
  position: relative;
  height: 28px;
  display: flex;
  align-items: center;
}

input[type=range] {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 4px;
  background: transparent;
  outline: none;
  cursor: pointer;
  position: relative;
  z-index: 2;
}
input[type=range]::-webkit-slider-runnable-track {
  height: 4px;
  border-radius: 2px;
  background: var(--navy10);
}
input[type=range]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--navy);
  border: 3px solid var(--white);
  box-shadow: 0 0 0 1.5px var(--navy), var(--shadow-sm);
  margin-top: -7px;
  transition: transform .1s, box-shadow .1s;
}
input[type=range]:hover::-webkit-slider-thumb,
input[type=range]:focus::-webkit-slider-thumb {
  transform: scale(1.15);
  box-shadow: 0 0 0 2px var(--blue), var(--shadow-md);
}
input[type=range]::-moz-range-thumb {
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--navy);
  border: 3px solid var(--white);
  box-shadow: 0 0 0 1.5px var(--navy);
}

.range-bar {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  left: 0; right: 0;
  height: 4px;
  border-radius: 2px;
  pointer-events: none;
  z-index: 1;
}
.range-fill {
  position: absolute;
  height: 100%;
  border-radius: 2px;
  transition: left .2s, width .2s, background .2s;
}
.range-normal {
  position: absolute;
  height: 100%;
  background: rgba(26,122,58,.18);
  border-radius: 2px;
}
.range-minmax {
  display: flex;
  justify-content: space-between;
  font-size: 10px;
  color: var(--muted);
  font-family: var(--mono);
  margin-top: 2px;
}

/* ─── Presets ─────────────────────────────────────────────── */
.presets-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
}
.preset-btn {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 8px 10px;
  cursor: pointer;
  text-align: left;
  transition: all .15s;
  font-family: var(--font);
}
.preset-btn:hover {
  background: var(--blue10);
  border-color: var(--blue);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}
.preset-btn.active {
  background: var(--navy);
  border-color: var(--navy);
}
.preset-name {
  font-size: 12px;
  font-weight: 500;
  color: var(--text);
  display: block;
}
.preset-btn.active .preset-name { color: #fff }
.preset-detail {
  font-size: 10px;
  color: var(--muted);
  font-family: var(--mono);
  display: block;
  margin-top: 1px;
}
.preset-btn.active .preset-detail { color: rgba(255,255,255,.6) }

/* ─── Checkboxes ──────────────────────────────────────────── */
.checkbox-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  border-radius: var(--r-md);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all .15s;
  margin-bottom: 6px;
  background: var(--bg);
}
.checkbox-row:hover { border-color: var(--blue); background: var(--blue10) }
.checkbox-row input { display: none }
.checkbox-box {
  width: 16px; height: 16px;
  border-radius: 4px;
  border: 1.5px solid var(--navy40);
  background: var(--white);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: all .15s;
}
.checkbox-row.checked .checkbox-box {
  background: var(--navy);
  border-color: var(--navy);
}
.checkbox-box svg { opacity: 0; transition: opacity .1s }
.checkbox-row.checked .checkbox-box svg { opacity: 1 }
.checkbox-text { font-size: 12px; font-weight: 500; color: var(--text) }

/* ─── Diagnosis result ────────────────────────────────────── */
.diag-card {
  border-radius: var(--r-xl);
  padding: 22px 24px;
  border: 1.5px solid transparent;
  transition: all .3s ease;
  box-shadow: var(--shadow-md);
  position: relative;
  overflow: hidden;
}
.diag-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  border-radius: var(--r-xl) var(--r-xl) 0 0;
  transition: background .3s;
}
.diag-card.acidosis { background: #fff5f7; border-color: rgba(222,23,56,.25) }
.diag-card.acidosis::before { background: var(--red) }
.diag-card.alkalosis { background: #f0f8ff; border-color: rgba(1,123,181,.25) }
.diag-card.alkalosis::before { background: var(--blue) }
.diag-card.normal { background: #f0fff5; border-color: rgba(26,122,58,.25) }
.diag-card.normal::before { background: #1a7a3a }
.diag-card.neutral { background: var(--white); border-color: var(--border) }

.diag-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 20px;
  margin-bottom: 10px;
}
.diag-tag.acidosis { background: var(--red20); color: #8b0f22 }
.diag-tag.alkalosis { background: var(--blue20); color: #014f77 }
.diag-tag.normal { background: rgba(26,122,58,.15); color: #0f4a22 }

.diag-primary {
  font-size: 20px;
  font-weight: 600;
  color: var(--navy);
  letter-spacing: -.02em;
  line-height: 1.3;
  margin-bottom: 6px;
  transition: all .2s;
}
.diag-ag {
  font-size: 13px;
  font-weight: 500;
  color: var(--muted);
  margin-bottom: 16px;
}
.diag-ag span {
  color: var(--text);
  font-weight: 500;
}

/* ─── pH validity warning ─────────────────────────────────── */
.ph-warning {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  background: rgba(222,23,56,.08);
  border: 1px solid rgba(222,23,56,.2);
  border-radius: var(--r-md);
  font-size: 12px;
  color: #8b0f22;
  margin-bottom: 10px;
  transition: opacity .2s;
}
.ph-warning.hidden { opacity: 0; pointer-events: none; height: 0; padding: 0; margin: 0; border: none; overflow: hidden }

/* ─── Explanation card ────────────────────────────────────── */
.explanation-box {
  margin-top: 6px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}
.explanation-title {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
}
.step-list { list-style: none; display: flex; flex-direction: column; gap: 7px }
.step-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13px;
  line-height: 1.5;
  animation: fadeSlide .25s ease both;
}
@keyframes fadeSlide {
  from { opacity: 0; transform: translateY(4px) }
  to   { opacity: 1; transform: translateY(0) }
}
.step-item:nth-child(1){animation-delay:.00s}
.step-item:nth-child(2){animation-delay:.05s}
.step-item:nth-child(3){animation-delay:.10s}
.step-item:nth-child(4){animation-delay:.15s}
.step-item:nth-child(5){animation-delay:.20s}
.step-item:nth-child(6){animation-delay:.25s}
.step-item:nth-child(7){animation-delay:.30s}
.step-num {
  width: 20px; height: 20px;
  border-radius: 50%;
  font-size: 11px;
  font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.step-num.gray   { background: var(--navy10); color: var(--navy) }
.step-num.red    { background: var(--red10); color: #8b0f22 }
.step-num.blue   { background: var(--blue10); color: #014f77 }
.step-num.green  { background: rgba(26,122,58,.12); color: #0f4a22 }
.step-num.amber  { background: rgba(185,120,0,.12); color: #7a4e00 }
.step-body { color: var(--text) }
.step-body b { font-weight: 600; color: var(--navy) }
.step-body .mono { font-family: var(--mono); font-size: 12px; background: var(--navy10); padding: 1px 5px; border-radius: 3px }

/* ─── Metrics grid ────────────────────────────────────────── */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}
.metric-tile {
  background: var(--bg);
  border-radius: var(--r-lg);
  padding: 12px 14px;
  border: 1px solid var(--border);
  transition: all .2s;
}
.metric-tile.highlight {
  background: var(--navy);
  border-color: var(--navy);
}
.metric-tile.warn {
  background: var(--red10);
  border-color: rgba(222,23,56,.25);
}
.metric-name {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 4px;
}
.metric-tile.highlight .metric-name { color: rgba(255,255,255,.6) }
.metric-tile.warn .metric-name { color: #8b0f22 }
.metric-val {
  font-family: var(--mono);
  font-size: 18px;
  font-weight: 500;
  color: var(--navy);
  line-height: 1;
  transition: all .2s;
}
.metric-tile.highlight .metric-val { color: #fff }
.metric-tile.warn .metric-val { color: #8b0f22 }
.metric-sub {
  font-size: 10px;
  color: var(--muted);
  margin-top: 3px;
  font-family: var(--mono);
}
.metric-tile.highlight .metric-sub { color: rgba(255,255,255,.5) }

/* ─── Ranges indicators ───────────────────────────────────── */
.range-indicators {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}
.ri-item {
  background: var(--bg);
  border-radius: var(--r-md);
  padding: 10px 12px;
  border: 1px solid var(--border);
}
.ri-label { font-size: 11px; color: var(--muted); font-weight: 500; margin-bottom: 6px }
.ri-bar {
  height: 6px;
  background: var(--navy10);
  border-radius: 3px;
  position: relative;
  overflow: hidden;
}
.ri-fill {
  height: 100%;
  border-radius: 3px;
  transition: width .3s ease, background .3s;
}
.ri-marker {
  position: absolute;
  top: -3px;
  width: 2px;
  height: 12px;
  border-radius: 1px;
  transform: translateX(-50%);
  transition: left .3s ease;
}
.ri-status {
  font-size: 10px;
  font-family: var(--mono);
  margin-top: 4px;
  font-weight: 500;
}
.ri-status.ok { color: #1a7a3a }
.ri-status.out { color: var(--red) }

/* ─── SIG section ─────────────────────────────────────────── */
.sig-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-bottom: 12px;
}
.sig-result {
  background: var(--navy);
  border-radius: var(--r-lg);
  padding: 16px 18px;
  color: #fff;
  margin-top: 4px;
}
.sig-result-label { font-size: 11px; color: rgba(255,255,255,.55); font-weight: 600; letter-spacing: .06em; text-transform: uppercase; margin-bottom: 4px }
.sig-result-val { font-family: var(--mono); font-size: 22px; font-weight: 500; line-height: 1; margin-bottom: 3px }
.sig-result-sub { font-size: 12px; color: rgba(255,255,255,.6) }
.sig-grid-results { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 12px }

.sig-note {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.6;
  padding: 10px 14px;
  background: var(--bg);
  border-radius: var(--r-md);
  border-left: 3px solid var(--blue);
  margin-top: 10px;
}

/* ─── Two column results ──────────────────────────────────── */
.results-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  align-items: start;
}

/* ─── Scrollbar ───────────────────────────────────────────── */
::-webkit-scrollbar { width: 5px }
::-webkit-scrollbar-track { background: transparent }
::-webkit-scrollbar-thumb { background: var(--navy20); border-radius: 3px }

/* ─── Tabs ────────────────────────────────────────────────── */
.tabs {
  display: flex;
  gap: 2px;
  background: var(--bg);
  border-radius: var(--r-md);
  padding: 3px;
  border: 1px solid var(--border);
}
.tab-btn {
  flex: 1;
  padding: 7px 12px;
  border: none;
  border-radius: calc(var(--r-md) - 2px);
  font-family: var(--font);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  background: transparent;
  color: var(--muted);
  transition: all .15s;
}
.tab-btn.active {
  background: var(--white);
  color: var(--navy);
  box-shadow: var(--shadow-sm);
}

.tab-panel { display: none }
.tab-panel.active { display: block }

/* ─── Responsive ──────────────────────────────────────────── */
@media (max-width: 900px) {
  .layout { grid-template-columns: 1fr }
  .sidebar { border-right: none; border-bottom: 1px solid var(--border) }
  .metrics-grid { grid-template-columns: repeat(2,1fr) }
  .results-row { grid-template-columns: 1fr }
  .sig-grid { grid-template-columns: repeat(2,1fr) }
}
@media (max-width: 600px) {
  .topbar { padding: 0 16px }
  .main { padding: 16px }
  .metrics-grid { grid-template-columns: repeat(2,1fr) }
  .range-indicators { grid-template-columns: 1fr 1fr }
  .presets-grid { grid-template-columns: 1fr }
}

/* ─── Numeric keyboard input paired with slider ──────────── */
.num-input {
  font-family: var(--mono);
  font-size: 13px;
  font-weight: 500;
  width: 62px;
  padding: 3px 7px;
  border: 1.5px solid var(--border);
  border-radius: var(--r-sm);
  background: var(--bg);
  color: var(--navy);
  text-align: right;
  outline: none;
  transition: border-color .15s, box-shadow .15s, background .15s;
  -moz-appearance: textfield;
}
.num-input::-webkit-outer-spin-button,
.num-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0 }
.num-input:hover { border-color: var(--navy20); background: var(--white) }
.num-input:focus {
  border-color: var(--blue);
  background: var(--white);
  box-shadow: 0 0 0 3px rgba(1,123,181,.15);
}
.num-input.out { border-color: rgba(222,23,56,.4); color: var(--red) }
.num-input.in  { border-color: rgba(26,122,58,.4); color: #1a7a3a }
.num-input.warn{ border-color: rgba(222,23,56,.5); color: #8b0f22; background: rgba(222,23,56,.04) }

/* ─── Batch tab styles ────────────────────────────────────── */
#drop-zone:hover { border-color: var(--blue); background: var(--blue10) }
#drop-zone.dragover { border-color: var(--blue); background: var(--blue10); transform:scale(1.01) }

.batch-case {
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  margin-bottom: 10px;
  overflow: hidden;
  transition: box-shadow .15s;
}
.batch-case:hover { box-shadow: var(--shadow-sm) }
.batch-case-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  cursor: pointer;
  background: var(--white);
  transition: background .15s;
  user-select: none;
}
.batch-case-header:hover { background: var(--bg) }
.batch-case.open .batch-case-header { background: var(--bg) }
.batch-case-num {
  width: 26px; height: 26px;
  border-radius: 50%;
  background: var(--navy);
  color: #fff;
  font-size: 11px; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.batch-case-id { font-size: 13px; font-weight: 500; color: var(--text) }
.batch-case-diag { font-size: 12px; color: var(--muted); flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis }
.batch-diag-badge {
  font-size: 10px; font-weight: 600; padding: 2px 8px;
  border-radius: 10px; white-space: nowrap; letter-spacing: .04em;
}
.badge-acid  { background: var(--red20); color: #8b0f22 }
.badge-alk   { background: var(--blue20); color: #014f77 }
.badge-norm  { background: rgba(26,122,58,.15); color: #0f4a22 }
.badge-mix   { background: rgba(185,120,0,.12); color: #7a4e00 }
.batch-chevron { color: var(--muted); font-size: 12px; transition: transform .2s }
.batch-case.open .batch-chevron { transform: rotate(90deg) }
.batch-case-body {
  display: none;
  padding: 0 16px 16px;
  background: var(--white);
  border-top: 1px solid var(--border);
}
.batch-case.open .batch-case-body { display: block }
.batch-inputs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
  gap: 6px;
  margin: 12px 0;
}
.batch-inp-tile {
  background: var(--bg);
  border-radius: var(--r-sm);
  padding: 6px 8px;
  border: 1px solid var(--border);
}
.batch-inp-lbl { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--muted) }
.batch-inp-val { font-family: var(--mono); font-size: 13px; font-weight: 500; color: var(--navy) }
.batch-diag-box {
  border-radius: var(--r-md);
  padding: 10px 14px;
  border-left: 3px solid transparent;
  margin-top: 8px;
}
.batch-diag-box.acidosis { background:#fff5f7; border-left-color:#de1738 }
.batch-diag-box.alkalosis { background:#f0f8ff; border-left-color:#017bb5 }
.batch-diag-box.normal { background:#f0fff5; border-left-color:#1a7a3a }
.batch-diag-primary { font-size:14px; font-weight:500; color:var(--navy); margin-bottom:2px }
.batch-diag-ag { font-size:12px; color:var(--muted) }
.batch-steps { margin-top:10px; list-style:none; display:flex; flex-direction:column; gap:5px }
.batch-step { display:flex; align-items:flex-start; gap:8px; font-size:11.5px; line-height:1.5 }
.batch-step-dot { width:16px; height:16px; border-radius:50%; font-size:9px; font-weight:600; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px }
.summary-pill { font-size:11px; font-weight:500; padding:4px 10px; border-radius:12px; border: 1px solid transparent }
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
<body>

<!-- Top bar -->
<header class="topbar">
  <div class="topbar-brand">
    <div class="topbar-logo">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <circle cx="9" cy="9" r="7" stroke="white" stroke-width="1.5"/>
        <line x1="2" y1="9" x2="16" y2="9" stroke="white" stroke-width="1.5"/>
        <path d="M9 2 Q13 9 9 16" stroke="white" stroke-width="1" fill="none"/>
      </svg>
    </div>
    <div>
      <div class="topbar-title">Acid-Base Analyser</div>
      <div class="topbar-sub">ABG Diagnostic Tool</div>
    </div>
  </div>
  <div class="topbar-badge">Atef Radwan</div>
</header>

<div class="layout">

<!-- ─── SIDEBAR ──────────────────────────────────────────── -->
<aside class="sidebar">

  <div class="section-label">Primary ABG</div>

  <div class="slider-row" id="row-pH">
    <div class="slider-header">
      <span class="slider-label">pH <span class="slider-unit">—</span></span>
      <input type="number" class="num-input" id="ni-pH" min="6.8" max="7.6" step="0.01" value="7.27">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-pH"></div>
        <div class="range-fill" id="rf-pH"></div>
      </div>
      <input type="range" id="sl-pH" min="6.80" max="7.60" step="0.01" value="7.27">
    </div>
    <div class="range-minmax"><span>6.80</span><span>Normal 7.35–7.45</span><span>7.60</span></div>
  </div>

  <div class="slider-row" id="row-pco2">
    <div class="slider-header">
      <span class="slider-label">PaCO₂ <span class="slider-unit">mm Hg</span></span>
      <input type="number" class="num-input" id="ni-pco2" min="8" max="113" step="0.25" value="39.8">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-pco2"></div>
        <div class="range-fill" id="rf-pco2"></div>
      </div>
      <input type="range" id="sl-pco2" min="8" max="113" step="0.25" value="39.75">
    </div>
    <div class="range-minmax"><span>8</span><span>Normal 35–45</span><span>113</span></div>
  </div>

  <div class="slider-row" id="row-hco3">
    <div class="slider-header">
      <span class="slider-label">HCO₃⁻ <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-hco3" min="2" max="46" step="0.1" value="17.6">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-hco3"></div>
        <div class="range-fill" id="rf-hco3"></div>
      </div>
      <input type="range" id="sl-hco3" min="2" max="46" step="0.1" value="17.6">
    </div>
    <div class="range-minmax"><span>2</span><span>Normal 22–28</span><span>46</span></div>
  </div>

  <div class="section-label">Electrolytes</div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">Na⁺ <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-na" min="110" max="165" step="1" value="125">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-na"></div>
        <div class="range-fill" id="rf-na"></div>
      </div>
      <input type="range" id="sl-na" min="110" max="165" step="1" value="125">
    </div>
    <div class="range-minmax"><span>110</span><span>Normal 136–145</span><span>165</span></div>
  </div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">Cl⁻ <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-cl" min="89" max="135" step="1" value="103">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-cl"></div>
        <div class="range-fill" id="rf-cl"></div>
      </div>
      <input type="range" id="sl-cl" min="89" max="135" step="1" value="103">
    </div>
    <div class="range-minmax"><span>89</span><span>Normal 98–107</span><span>135</span></div>
  </div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">Albumin <span class="slider-unit">g/L</span></span>
      <input type="number" class="num-input" id="ni-alb" min="11" max="44" step="1" value="29">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-alb"></div>
        <div class="range-fill" id="rf-alb"></div>
      </div>
      <input type="range" id="sl-alb" min="11" max="44" step="1" value="29">
    </div>
    <div class="range-minmax"><span>11</span><span>Normal 35–50</span><span>44</span></div>
  </div>

  <div class="section-label">SIG Inputs</div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">K⁺ <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-k" min="1.5" max="8.5" step="0.1" value="4.4">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-k"></div>
        <div class="range-fill" id="rf-k"></div>
      </div>
      <input type="range" id="sl-k" min="1.5" max="8.5" step="0.1" value="4.4">
    </div>
    <div class="range-minmax"><span>1.5</span><span>Normal 3.5–5</span><span>8.5</span></div>
  </div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">Ca²⁺ <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-ca" min="0.5" max="3.0" step="0.05" value="1.0">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-ca"></div>
        <div class="range-fill" id="rf-ca"></div>
      </div>
      <input type="range" id="sl-ca" min="0.5" max="3.0" step="0.05" value="1.0">
    </div>
    <div class="range-minmax"><span>0.5</span><span>Normal 1.1–1.4</span><span>3.0</span></div>
  </div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">Mg²⁺ <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-mg" min="0.3" max="3.0" step="0.05" value="1.0">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-mg"></div>
        <div class="range-fill" id="rf-mg"></div>
      </div>
      <input type="range" id="sl-mg" min="0.3" max="3.0" step="0.05" value="1.0">
    </div>
    <div class="range-minmax"><span>0.3</span><span>Normal 0.7–1.0</span><span>3.0</span></div>
  </div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">Lactate <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-lac" min="0.2" max="15" step="0.1" value="2.5">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-lac"></div>
        <div class="range-fill" id="rf-lac"></div>
      </div>
      <input type="range" id="sl-lac" min="0.2" max="15" step="0.1" value="2.5">
    </div>
    <div class="range-minmax"><span>0.2</span><span>Normal &lt;2.0</span><span>15</span></div>
  </div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">PO₄ <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-po4" min="0.2" max="3.0" step="0.05" value="1.2">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-po4"></div>
        <div class="range-fill" id="rf-po4"></div>
      </div>
      <input type="range" id="sl-po4" min="0.2" max="3.0" step="0.05" value="1.2">
    </div>
    <div class="range-minmax"><span>0.2</span><span>Normal 0.8–1.4</span><span>3.0</span></div>
  </div>

  <div class="slider-row">
    <div class="slider-header">
      <span class="slider-label">+ve Std Base Deficit <span class="slider-unit">mmol/L</span></span>
      <input type="number" class="num-input" id="ni-sbd" min="0" max="30" step="0.1" value="7.8">
    </div>
    <div class="slider-track">
      <div class="range-bar">
        <div class="range-normal" id="rn-sbd"></div>
        <div class="range-fill" id="rf-sbd"></div>
      </div>
      <input type="range" id="sl-sbd" min="0" max="30" step="0.1" value="7.8">
    </div>
    <div class="range-minmax"><span>0</span><span>Must be +ve</span><span>30</span></div>
  </div>

  <div class="section-label">Options</div>

  <div id="urc-slider-block" style="display:none;margin-bottom:14px;padding:12px 14px;background:rgba(222,23,56,.06);border:1.5px solid rgba(222,23,56,.35);border-radius:10px">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#8b0f22" stroke-width="1.4"/><line x1="7" y1="4" x2="7" y2="7.5" stroke="#8b0f22" stroke-width="1.6" stroke-linecap="round"/><circle cx="7" cy="9.5" r=".85" fill="#8b0f22"/></svg>
      <span style="font-size:11px;font-weight:600;color:#8b0f22;letter-spacing:.05em;text-transform:uppercase">Required for this diagnosis</span>
    </div>
    <div class="slider-row" style="margin-bottom:0">
      <div class="slider-header">
        <span class="slider-label">Ur. Chloride <span class="slider-unit">mmol/L</span></span>
        <input type="number" class="num-input" id="ni-urc" min="0" max="80" step="1" value="20">
      </div>
      <div class="slider-track">
        <div class="range-bar">
          <div class="range-fill" id="rf-urc"></div>
        </div>
        <input type="range" id="sl-urc" min="0" max="80" step="1" value="20">
      </div>
      <div class="range-minmax"><span>0</span><span>&lt;20 responsive · ≥20 resistant</span><span>80</span></div>
    </div>
  </div>

  <label class="checkbox-row" id="chk-cco2-row">
    <input type="checkbox" id="chk-cco2">
    <div class="checkbox-box">
      <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <span class="checkbox-text">Chronic CO₂ Retention</span>
  </label>

  <label class="checkbox-row" id="chk-exac-row">
    <input type="checkbox" id="chk-exac">
    <div class="checkbox-box">
      <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <span class="checkbox-text">Exacerbation</span>
  </label>

  <div class="section-label">Presets</div>
  <div class="presets-grid" id="presets-grid"></div>

</aside>

<!-- ─── MAIN ────────────────────────────────────────────── -->
<main class="main">

  <!-- UrC required prompt -->
  <div class="ph-warning hidden" id="urc-required" style="border-color:rgba(222,23,56,.35);background:rgba(222,23,56,.06)">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#8b0f22" stroke-width="1.3"/><line x1="7" y1="4" x2="7" y2="7.5" stroke="#8b0f22" stroke-width="1.5" stroke-linecap="round"/><circle cx="7" cy="9.5" r=".8" fill="#8b0f22"/></svg>
    <span>Urinary chloride is required to complete this diagnosis — scroll up in the left panel to enter it.</span>
  </div>

  <!-- pH warning -->
  <div class="ph-warning hidden" id="ph-warning">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#8b0f22" stroke-width="1.3"/><line x1="7" y1="4" x2="7" y2="7.5" stroke="#8b0f22" stroke-width="1.5" stroke-linecap="round"/><circle cx="7" cy="9.5" r=".8" fill="#8b0f22"/></svg>
    <span id="ph-warning-text"></span>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('abg')">ABG Diagnosis</button>
    <button class="tab-btn" onclick="switchTab('sig')">SIG / BDE Analysis</button>
    <button class="tab-btn" onclick="switchTab('batch')">Batch Import</button>
  </div>

  <!-- ── ABG TAB ─── -->
  <div class="tab-panel active" id="tab-abg">

    <!-- Diagnosis card -->
    <div class="diag-card neutral" id="diag-card">
      <div class="diag-tag neutral" id="diag-tag">Awaiting input</div>
      <div class="diag-primary" id="diag-primary">—</div>
      <div class="diag-ag" id="diag-ag"></div>

      <div class="explanation-box">
        <div class="explanation-title">Decision path</div>
        <ul class="step-list" id="step-list"></ul>
      </div>
    </div>

    <!-- Metrics -->
    <div class="card">
      <div class="card-title"><span class="card-title-dot"></span>Calculated values</div>
      <div class="metrics-grid">
        <div class="metric-tile" id="mt-calcph">
          <div class="metric-name">Calc. pH</div>
          <div class="metric-val" id="mv-calcph">—</div>
          <div class="metric-sub" id="ms-calcph">Henderson-Hasselbalch</div>
        </div>
        <div class="metric-tile" id="mt-ag">
          <div class="metric-name">Corr. AG</div>
          <div class="metric-val" id="mv-ag">—</div>
          <div class="metric-sub">Na−(Cl+HCO₃)+0.25×(44−Alb)</div>
        </div>
        <div class="metric-tile" id="mt-hg">
          <div class="metric-name">HCO₃ gap</div>
          <div class="metric-val" id="mv-hg">—</div>
          <div class="metric-sub">Na−Cl−36 (delta-delta)</div>
        </div>
        <div class="metric-tile" id="mt-be">
          <div class="metric-name">SID gap</div>
          <div class="metric-val" id="mv-sidgap">—</div>
          <div class="metric-sub">SIDapp − SIDeff</div>
        </div>
      </div>
    </div>

    <!-- Range indicators -->
    <div class="card">
      <div class="card-title"><span class="card-title-dot"></span>Reference ranges</div>
      <div class="range-indicators">
        <div class="ri-item">
          <div class="ri-label">pH (7.35–7.45)</div>
          <div class="ri-bar"><div class="range-normal" id="rin-pH"></div><div class="ri-fill" id="rif-pH"></div><div class="ri-marker" id="rim-pH"></div></div>
          <div class="ri-status" id="ris-pH">—</div>
        </div>
        <div class="ri-item">
          <div class="ri-label">PaCO₂ (35–45 mm Hg)</div>
          <div class="ri-bar"><div class="range-normal" id="rin-pco2"></div><div class="ri-fill" id="rif-pco2"></div><div class="ri-marker" id="rim-pco2"></div></div>
          <div class="ri-status" id="ris-pco2">—</div>
        </div>
        <div class="ri-item">
          <div class="ri-label">HCO₃⁻ (22–28 mmol/L)</div>
          <div class="ri-bar"><div class="range-normal" id="rin-hco3"></div><div class="ri-fill" id="rif-hco3"></div><div class="ri-marker" id="rim-hco3"></div></div>
          <div class="ri-status" id="ris-hco3">—</div>
        </div>
      </div>
    </div>

  </div><!-- /tab-abg -->

  <!-- ── SIG TAB ─── -->
  <div class="tab-panel" id="tab-sig">
    <div class="card">
      <div class="card-title"><span class="card-title-dot"></span>Strong ion gap &amp; BDE gap</div>

      <div class="sig-grid">
        <div class="metric-tile" id="sig-k-tile">
          <div class="metric-name">K⁺</div>
          <div class="metric-val" id="sig-k-val">—</div>
          <div class="metric-sub">mmol/L</div>
        </div>
        <div class="metric-tile" id="sig-ca-tile">
          <div class="metric-name">Ca²⁺</div>
          <div class="metric-val" id="sig-ca-val">—</div>
          <div class="metric-sub">mmol/L</div>
        </div>
        <div class="metric-tile" id="sig-mg-tile">
          <div class="metric-name">Mg²⁺</div>
          <div class="metric-val" id="sig-mg-val">—</div>
          <div class="metric-sub">mmol/L</div>
        </div>
        <div class="metric-tile" id="sig-lac-tile">
          <div class="metric-name">Lactate</div>
          <div class="metric-val" id="sig-lac-val">—</div>
          <div class="metric-sub">mmol/L</div>
        </div>
        <div class="metric-tile" id="sig-po4-tile">
          <div class="metric-name">PO₄</div>
          <div class="metric-val" id="sig-po4-val">—</div>
          <div class="metric-sub">mmol/L</div>
        </div>
        <div class="metric-tile" id="sig-sbd-tile">
          <div class="metric-name">+ve Std BD</div>
          <div class="metric-val" id="sig-sbd-val">—</div>
          <div class="metric-sub">mmol/L</div>
        </div>
      </div>

      <div class="sig-grid-results">
        <div class="sig-result" id="sig-result-box">
          <div class="sig-result-label">SIG (XA)</div>
          <div class="sig-result-val" id="sig-val">—</div>
          <div class="sig-result-sub" id="sig-interp">—</div>
        </div>
        <div class="sig-result" style="background:var(--blue)" id="bde-result-box">
          <div class="sig-result-label">BDE Gap</div>
          <div class="sig-result-val" id="bde-val">—</div>
          <div class="sig-result-sub" id="bde-interp">—</div>
        </div>
      </div>

      <div class="sig-note" id="sig-note">
        SIG = (Na⁺ + Ca²⁺ + Mg²⁺ + K⁺) − (Cl⁻ + Lactate) − (HCO₃⁻ + Albumin × (0.123 × pH − 0.631) + PO₄ × (0.309 × pH − 0.469))<br>
        BDE Gap = −(Std Base Deficit) − (Na⁺ − Cl⁻ − 38) + 0.25 × (42 − Albumin)
      </div>

      <div style="margin-top:14px">
        <div class="explanation-title" style="margin-bottom:8px">Interpretation</div>
        <ul class="step-list" id="sig-steps"></ul>
      </div>
    </div>
  </div><!-- /tab-sig -->


  <!-- ── BATCH TAB ─── -->
  <div class="tab-panel" id="tab-batch">

    <!-- Step 1 – Download template -->
    <div class="card" style="margin-bottom:14px">
      <div class="card-title"><span class="card-title-dot"></span>Step 1 — download template</div>
      <p style="font-size:13px;color:var(--muted);margin-bottom:14px;line-height:1.6">Download the Excel template, fill in your cases (one per row), then import it below. All columns with a <span style="color:#8b0f22;font-weight:500">*</span> are required for the ABG diagnosis; electrolyte and SIG columns are used where provided.</p>
      <button onclick="downloadTemplate()" style="display:inline-flex;align-items:center;gap:8px;padding:9px 18px;background:var(--navy);color:#fff;border:none;border-radius:var(--r-md);font-family:var(--font);font-size:13px;font-weight:500;cursor:pointer">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v8M4 7l3 3 3-3M2 11h10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Download Excel template (5 cases)
      </button>
    </div>

    <!-- Step 2 – Import -->
    <div class="card" style="margin-bottom:14px">
      <div class="card-title"><span class="card-title-dot"></span>Step 2 — import completed file</div>
      <div id="drop-zone" onclick="document.getElementById('file-input').click()" style="border:2px dashed var(--border);border-radius:var(--r-lg);padding:32px 20px;text-align:center;cursor:pointer;transition:all .2s;background:var(--bg)">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" style="margin:0 auto 10px;display:block"><rect x="4" y="4" width="20" height="20" rx="4" stroke="#6b88a2" stroke-width="1.5"/><path d="M14 9v10M10 15l4 4 4-4" stroke="#6b88a2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div style="font-size:13px;font-weight:500;color:var(--muted)">Click to choose file or drag &amp; drop</div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px">.xlsx or .csv accepted</div>
      </div>
      <input type="file" id="file-input" accept=".xlsx,.csv" style="display:none" onchange="handleFileImport(this.files[0])">
      <div id="import-status" style="display:none;margin-top:10px;padding:9px 12px;border-radius:var(--r-md);font-size:12px"></div>
    </div>

    <!-- Step 3 – Results -->
    <div id="batch-results-section" style="display:none">
      <div class="card" style="margin-bottom:14px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px">
          <div class="card-title" style="margin:0"><span class="card-title-dot"></span>Results — <span id="batch-case-count">0</span> cases</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button onclick="exportBatchExcel()" style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:var(--navy);color:#fff;border:none;border-radius:var(--r-md);font-family:var(--font);font-size:12px;font-weight:500;cursor:pointer">
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 1v8M4 7l3 3 3-3M2 11h10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Export Excel
            </button>
            <button onclick="exportBatchPDF()" style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:var(--blue);color:#fff;border:none;border-radius:var(--r-md);font-family:var(--font);font-size:12px;font-weight:500;cursor:pointer">
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 1v8M4 7l3 3 3-3M2 11h10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Export PDF
            </button>
          </div>
        </div>
        <!-- Summary pills -->
        <div id="batch-summary-pills" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px"></div>
        <!-- Cases accordion -->
        <div id="batch-cases-list"></div>
      </div>
    </div>

  </div><!-- /tab-batch -->
</main>
</div>

<script>
const ph1=7.3,ph2=7.5,p2=45;

const PRESETS=[
  {name:'Normal ABG',      detail:'pH 7.40  PCO₂ 40  HCO₃ 24', pH:7.40,pco2:40,hco3:24,na:140,cl:102,alb:40,k:4.0,ca:1.2,mg:0.8,lac:1.0,po4:1.0,sbd:1.0},
  {name:'Resp. acidosis',  detail:'pH 7.20  PCO₂ 65  HCO₃ 24', pH:7.20,pco2:65,hco3:24,na:138,cl:102,alb:38,k:4.0,ca:1.2,mg:0.8,lac:1.2,po4:1.1,sbd:2.0},
  {name:'Resp. alkalosis', detail:'pH 7.52  PCO₂ 28  HCO₃ 22', pH:7.52,pco2:28,hco3:22,na:138,cl:103,alb:38,k:3.8,ca:1.2,mg:0.8,lac:1.0,po4:1.0,sbd:1.5},
  {name:'Met. acidosis',   detail:'pH 7.27  PCO₂ 40  HCO₃ 17', pH:7.27,pco2:39.75,hco3:17.6,na:125,cl:103,alb:29,k:4.4,ca:1.0,mg:1.0,lac:2.5,po4:1.2,sbd:7.8},
  {name:'Met. alkalosis',  detail:'pH 7.51  PCO₂ 48  HCO₃ 36', pH:7.51,pco2:48,hco3:36,na:142,cl:96,alb:38,k:3.2,ca:1.1,mg:0.8,lac:1.0,po4:1.0,sbd:1.0},
  {name:'Mixed acid+alk',  detail:'pH 7.44  PCO₂ 28  HCO₃ 18', pH:7.44,pco2:27.75,hco3:18.2,na:135,cl:110,alb:32,k:3.7,ca:1.1,mg:0.9,lac:1.6,po4:1.1,sbd:4.2},
];

let activePreset=-1;

function buildPresets(){
  const grid=document.getElementById('presets-grid');
  grid.innerHTML=PRESETS.map((p,i)=>`
    <button class="preset-btn" id="pb-${i}" onclick="applyPreset(${i})">
      <span class="preset-name">${p.name}</span>
      <span class="preset-detail">${p.detail}</span>
    </button>`).join('');
}

function applyPreset(i){
  const p=PRESETS[i];
  setSlider('sl-pH',p.pH);
  setSlider('sl-pco2',p.pco2);
  setSlider('sl-hco3',p.hco3);
  setSlider('sl-na',p.na);
  setSlider('sl-cl',p.cl);
  setSlider('sl-alb',p.alb);
  setSlider('sl-k',p.k);
  setSlider('sl-ca',p.ca);
  setSlider('sl-mg',p.mg);
  setSlider('sl-lac',p.lac);
  setSlider('sl-po4',p.po4);
  setSlider('sl-sbd',p.sbd);
  if(activePreset>=0) document.getElementById('pb-'+activePreset)?.classList.remove('active');
  document.getElementById('pb-'+i)?.classList.add('active');
  activePreset=i;
  update();
}

function setSlider(id,val){
  document.getElementById(id).value=val;
  const niId='ni-'+id.replace(/^sl-/,'');
  const ni=document.getElementById(niId);
  if(ni){ const sl=document.getElementById(id); const dp=sl.step&&sl.step.includes('.')?sl.step.split('.')[1].length:0; ni.value=dp===0?Math.round(val):parseFloat(val).toFixed(dp); }
}
function g(id){return parseFloat(document.getElementById(id).value)}

function pct(val,min,max){return Math.max(0,Math.min(100,(val-min)/(max-min)*100))}

function updateSliderVisual(slId,rfId,rnId,vvId,min,max,nLo,nHi,dp=2){
  const val=g(slId);
  const p=pct(val,min,max);
  const inRange=(val>=nLo&&val<=nHi);
  const fill=document.getElementById(rfId);
  const norm=document.getElementById(rnId);
  // Sync the number input (vvId is now the num-input id via the ni- prefix)
  const niId='ni-'+vvId.replace(/^vv-/,'');
  const ni=document.getElementById(niId);
  if(fill){fill.style.cssText=`left:0;width:${p.toFixed(1)}%;background:${inRange?'#1a7a3a':'#de1738'}`;}
  if(norm){
    const nLeft=pct(nLo,min,max);
    const nWidth=pct(nHi,min,max)-nLeft;
    norm.style.cssText=`left:${nLeft.toFixed(1)}%;width:${nWidth.toFixed(1)}%`;
  }
  if(ni&&document.activeElement!==ni){
    ni.value=dp===0?Math.round(val):val.toFixed(dp);
    ni.className='num-input '+(inRange?'in':'out');
  }
}

function updateRangeIndicator(fillId,markId,statusId,val,min,max,nLo,nHi,label,dp=2){
  const f=document.getElementById(fillId);
  const m=document.getElementById(markId);
  const s=document.getElementById(statusId);
  const inRange=(val>=nLo&&val<=nHi);
  const p=pct(val,min,max);
  if(f) f.style.cssText=`width:${p.toFixed(1)}%;background:${inRange?'#1a7a3a':'#de1738'}`;
  if(m) m.style.cssText=`left:${p.toFixed(1)}%;background:${inRange?'#0f4a22':'#8b0f22'}`;
  if(s){
    const dir=val<nLo?'↓ low':val>nHi?'↑ high':'✓ normal';
    s.textContent=`${val.toFixed(dp)} ${dir}`;
    s.className='ri-status '+(inRange?'ok':'out');
  }
}

function step(num,cls,html){
  return `<li class="step-item"><div class="step-num ${cls}">${num}</div><div class="step-body">${html}</div></li>`;
}
function mono(v){return `<span class="mono">${v}</span>`}

function update(){
  const pH=g('sl-pH'), pv=g('sl-pco2'), hv=g('sl-hco3');
  const nav=g('sl-na'), clv=g('sl-cl'), alb=g('sl-alb');
  const K=g('sl-k'), Ca=g('sl-ca'), Mg=g('sl-mg'), lac=g('sl-lac'), po4=g('sl-po4'), sbd=g('sl-sbd');
  const cco2=document.getElementById('chk-cco2').checked;
  const exac=document.getElementById('chk-exac').checked;

  updateSliderVisual('sl-pH','rf-pH','rn-pH','vv-pH',6.80,7.60,7.35,7.45,2);
  updateSliderVisual('sl-pco2','rf-pco2','rn-pco2','vv-pco2',8,113,35,45,1);
  updateSliderVisual('sl-hco3','rf-hco3','rn-hco3','vv-hco3',2,46,22,28,1);
  updateSliderVisual('sl-na','rf-na','rn-na','vv-na',110,165,136,145,0);
  updateSliderVisual('sl-cl','rf-cl','rn-cl','vv-cl',89,135,98,107,0);
  updateSliderVisual('sl-alb','rf-alb','rn-alb','vv-alb',11,44,35,50,0);
  updateSliderVisual('sl-k','rf-k','rn-k','vv-k',1.5,8.5,3.5,5.0,1);
  updateSliderVisual('sl-ca','rf-ca','rn-ca','vv-ca',0.5,3.0,1.1,1.4,2);
  updateSliderVisual('sl-mg','rf-mg','rn-mg','vv-mg',0.3,3.0,0.7,1.0,2);
  updateSliderVisual('sl-lac','rf-lac','rn-lac','vv-lac',0.2,15,0,2.0,1);
  updateSliderVisual('sl-po4','rf-po4','rn-po4','vv-po4',0.2,3.0,0.8,1.4,2);
  updateSliderVisual('sl-sbd','rf-sbd','rn-sbd','vv-sbd',0,30,0,2,1);

  updateRangeIndicator('rif-pH','rim-pH','ris-pH',pH,6.80,7.60,7.35,7.45,'pH',2);
  updateRangeIndicator('rif-pco2','rim-pco2','ris-pco2',pv,8,113,35,45,'PaCO₂',1);
  updateRangeIndicator('rif-hco3','rim-hco3','ris-hco3',hv,2,46,22,28,'HCO₃',1);

  const pHc=6.1+Math.log10(hv/(0.03*pv));
  const diff=Math.abs(pHc-pH);
  const AG=nav-(clv+hv)+0.25*(44-alb);
  const HG=nav-clv-36;
  const wlo=(0.9*(1.5*hv+4)), whi=(1.1*(1.5*hv+12));
  const mlo=(0.9*(0.7*hv+15)), mhi=(1.1*(0.7*hv+15));

  // pH warning
  const warn=document.getElementById('ph-warning');
  if(diff>0.1){
    warn.classList.remove('hidden');
    document.getElementById('ph-warning-text').textContent=
      `Henderson-Hasselbalch check: calculated pH = ${pHc.toFixed(2)}, difference = ${diff.toFixed(2)} — please review inputs`;
  } else { warn.classList.add('hidden'); }

  // Calculated metrics
  document.getElementById('mv-calcph').textContent=pHc.toFixed(2);
  document.getElementById('mv-ag').textContent=AG.toFixed(1);
  document.getElementById('mv-hg').textContent=HG.toFixed(1);
  const sid_app=nav+Ca+Mg+K;
  const sid_eff=hv+alb*(0.123*pH-0.631)+po4*(0.309*pH-0.469);
  document.getElementById('mv-sidgap').textContent=(sid_app-clv-lac-sid_eff).toFixed(1);

  const mt_ag=document.getElementById('mt-ag');
  if(AG>12){mt_ag.classList.add('warn');mt_ag.classList.remove('highlight');}
  else if(AG<=12&&AG>0){mt_ag.classList.remove('warn','highlight');}

  // ── Diagnosis engine ────────────────────────────────
  let Diag='', AGdiag='', steps=[], diagClass='neutral', tagClass='neutral', tagLabel='Analysing…', needsUrC=false;

  steps.push(step(1,'gray',`<b>pH validity:</b> calculated pH = ${mono(pHc.toFixed(2))}, entered = ${mono(pH.toFixed(2))}, Δ = ${mono(diff.toFixed(2))} ${diff>0.1?'<span style="color:#de1738">— inputs inconsistent</span>':'— consistent ✓'}`));

  // CCO2 special branches
  if(cco2){
    if(pH<7.3&&pv<=57&&hv<24&&!exac){
      Diag='Chronic Respiratory Acidosis + Metabolic Acidosis';
      diagClass='acidosis';tagClass='acidosis';tagLabel='Mixed acidosis';
      steps.push(step(2,'red','<b>Chronic CO₂ retention + exacerbation criteria:</b> pH &lt;7.30, PaCO₂ ≤57, HCO₃ &lt;24, no exacerbation flag'));
      steps.push(step(3,'red','→ Chronic respiratory acidosis with superimposed metabolic acidosis'));
    } else if(pH<7.3&&pv>2*hv-8&&hv>=30&&exac){
      Diag='Acute on Top of Chronic Respiratory Acidosis';
      diagClass='acidosis';tagClass='acidosis';tagLabel='Acute-on-chronic';
      steps.push(step(2,'red',`<b>Acute-on-chronic criteria:</b> pH &lt;7.30, PaCO₂ ${mono(pv.toFixed(1))} > ${mono((2*hv-8).toFixed(1))} (2×HCO₃−8), HCO₃ ≥30`));
    } else if(pH<7.3&&pv>57&&hv<24&&exac){
      Diag='Acute on Chronic Respiratory Acidosis + Metabolic Acidosis';
      diagClass='acidosis';tagClass='acidosis';tagLabel='Mixed acidosis';
      steps.push(step(2,'red','<b>Acute-on-chronic + met. acidosis:</b> pH &lt;7.30, PaCO₂ >57, HCO₃ &lt;24, exacerbation flagged'));
    } else if(pH>=7.4){
      const thresh=0.92*(2*hv-8);
      const urc=g('sl-urc');
      const urcEntered=document.getElementById('sl-urc').dataset.entered==='1';
      const thresh_met=(pv<=thresh);
      diagClass='alkalosis';tagClass='alkalosis';tagLabel='Mixed alk.';
      steps.push(step(2,'blue',`<b>Chronic CO₂ + alkalosis:</b> pH ≥7.40, PaCO₂ threshold = ${mono(thresh.toFixed(1))}, actual = ${mono(pv.toFixed(1))}`));
      if(!urcEntered){
        Diag='Chronic Respiratory Acidosis + Metabolic Alkalosis (subtype pending)';
        steps.push(step(3,'red','<b>Urinary chloride required</b> — enter it in the left panel to complete classification'));
        needsUrC=true;
      } else {
        steps.push(step(3,'blue',`Ur. Chloride = ${mono(urc+' mmol/L')} (${urc<20?'< 20 — chloride-responsive':'≥ 20 — chloride-resistant/independent'})`));
        if(thresh_met){
          if(urc<20){ Diag='Chronic Respiratory Acidosis + Metabolic Alkalosis (Post-Hypercapnic)'; steps.push(step(4,'blue','PaCO₂ ≤ threshold, Ur.Cl &lt; 20 → <b>Post-Hypercapnic</b> (volume/chloride depletion)')); }
          else       { Diag='Chronic Respiratory Acidosis + Metabolic Alkalosis (Mixed)'; steps.push(step(4,'blue','PaCO₂ ≤ threshold, Ur.Cl ≥ 20 → <b>Mixed</b> (primary + post-hypercapnic)')); }
        } else {
          if(urc>=20){ Diag='Chronic Respiratory Acidosis + Metabolic Alkalosis (Independent, Chloride-Resistant / Diuresis)'; steps.push(step(4,'blue','PaCO₂ > threshold, Ur.Cl ≥ 20 → <b>Independent, chloride-resistant</b> (hyperaldosteronism / diuretics)')); }
          else       { Diag='Chronic Respiratory Acidosis + Metabolic Alkalosis (Independent, Chloride-Responsive, Extra-Renal Cl⁻ Loss)'; steps.push(step(4,'blue','PaCO₂ > threshold, Ur.Cl &lt; 20 → <b>Independent, chloride-responsive</b> (extra-renal chloride loss)')); }
        }
      }
    }
  }

  if(!Diag){
    if(pH>=7.35&&pH<=7.45&&pv>=35&&pv<=45&&hv>=22&&hv<=28){
      Diag='Normal ABG — Check Anion Gap';
      diagClass='normal';tagClass='normal';tagLabel='Normal';
      steps.push(step(2,'green',`All three values within reference range: pH ${mono(pH.toFixed(2))}, PaCO₂ ${mono(pv.toFixed(1))}, HCO₃ ${mono(hv.toFixed(1))}`));
      steps.push(step(3,'green','<b>Note:</b> AG calculation is a manual clinical step — not auto-triggered for normal ABG'));
    } else if(pH<7.4){
      steps.push(step(2,'red',`<b>pH ${pH.toFixed(2)} &lt; 7.40</b> → acidaemia`));
      tagLabel='Acidosis'; tagClass='acidosis'; diagClass='acidosis';
      if(pv>=p2){
        steps.push(step(3,'red',`<b>PaCO₂ ${pv.toFixed(1)} ≥ 45</b> → primary respiratory mechanism (hypercapnia driving acidosis)`));
        const acute=(pH<ph1||pH>ph2);
        const mult=acute?1:4;
        const eq=22-((40-pv)/10)*mult, eq1=28-((40-pv)/10)*mult;
        steps.push(step(4,'amber',`<b>${acute?'Acute':'Chronic'}:</b> pH ${acute?'outside (< 7.30 or > 7.50)':'within 7.30–7.50'} → multiplier = ${mono(mult)}`));
        steps.push(step(5,'amber',`Expected HCO₃ range: ${mono(eq.toFixed(1)+' – '+eq1.toFixed(1))} | Actual: ${mono(hv.toFixed(1))}`));
        if(hv>eq&&hv<eq1){
          Diag=`Simple ${acute?'Acute':'Chronic'} Respiratory Acidosis`;
          steps.push(step(6,'red','HCO₃ within expected range → <b>Simple</b> — adequate compensation'));
        } else if(hv<=eq){
          Diag=`${acute?'Acute':'Chronic'} Respiratory Acidosis + Metabolic Acidosis`;
          steps.push(step(6,'red',`HCO₃ ${mono(hv.toFixed(1))} <b>below</b> lower expected ${mono(eq.toFixed(1))} → additional metabolic acidosis`));
        } else {
          Diag=`${acute?'Acute':'Chronic'} Respiratory Acidosis + Metabolic Alkalosis`;
          steps.push(step(6,'blue',`HCO₃ ${mono(hv.toFixed(1))} <b>above</b> upper expected ${mono(eq1.toFixed(1))} → concurrent metabolic alkalosis`));
        }
      } else {
        steps.push(step(3,'amber',`<b>PaCO₂ ${pv.toFixed(1)} &lt; 45</b> → primary metabolic mechanism (bicarbonate deficit)`));
        const comp=(pH>=ph1&&pH<=ph2)?'Compensated ':((pv>=35&&pv<=45)?'Uncompensated ':'Partially Compensated ');
        steps.push(step(4,'amber',`<b>${comp.trim()}:</b> pH ${pH>=ph1&&pH<=ph2?`within 7.30–7.50`:`outside 7.30–7.50`}, PaCO₂ ${pv>=35&&pv<=45?'normal':'abnormal'}`));
        steps.push(step(5,'amber',`Winters' formula → expected PaCO₂: ${mono(wlo.toFixed(1)+' – '+whi.toFixed(1))} | Actual: ${mono(pv.toFixed(1))}`));
        if(pv>=wlo&&pv<=whi){
          Diag=comp+'Simple Metabolic Acidosis';
          steps.push(step(6,'red','PaCO₂ within Winters\' range → <b>simple</b> with appropriate respiratory compensation'));
        } else if(pv<wlo){
          Diag=comp+'Metabolic Acidosis + Respiratory Alkalosis';
          steps.push(step(6,'red',`PaCO₂ ${mono(pv.toFixed(1))} <b>below</b> Winters' lower bound ${mono(wlo.toFixed(1))} → superimposed respiratory alkalosis`));
        } else {
          Diag=comp+'Metabolic Acidosis + Respiratory Acidosis';
          steps.push(step(6,'red',`PaCO₂ ${mono(pv.toFixed(1))} <b>above</b> Winters' upper bound ${mono(whi.toFixed(1))} → superimposed respiratory acidosis`));
        }
      }
    } else {
      steps.push(step(2,'blue',`<b>pH ${pH.toFixed(2)} ≥ 7.40</b> → alkalaemia`));
      tagLabel='Alkalosis'; tagClass='alkalosis'; diagClass='alkalosis';
      if(pv<35){
        steps.push(step(3,'blue',`<b>PaCO₂ ${pv.toFixed(1)} &lt; 35</b> → primary respiratory mechanism (hypocapnia driving alkalosis)`));
        const acute=(pH>ph2);
        const mult=acute?2:5;
        const eq=22-((40-pv)/10)*mult, eq1=28-((40-pv)/10)*mult;
        steps.push(step(4,'amber',`<b>${acute?'Acute':'Chronic'}:</b> pH ${acute?'> 7.50':'≤ 7.50'} → multiplier = ${mono(mult)}`));
        steps.push(step(5,'amber',`Expected HCO₃ range: ${mono(eq.toFixed(1)+' – '+eq1.toFixed(1))} | Actual: ${mono(hv.toFixed(1))}`));
        if(hv>eq&&hv<eq1){
          Diag=`Simple ${acute?'Acute':'Chronic'} Respiratory Alkalosis`;
          steps.push(step(6,'blue','HCO₃ within expected → <b>Simple</b> — appropriate compensation'));
        } else if(hv<=eq){
          Diag=`${acute?'Acute':'Chronic'} Respiratory Alkalosis + Metabolic Acidosis`;
          steps.push(step(6,'red',`HCO₃ <b>below</b> expected lower bound → concurrent metabolic acidosis`));
        } else {
          Diag=`${acute?'Acute':'Chronic'} Respiratory Alkalosis + Metabolic Alkalosis`;
          steps.push(step(6,'blue',`HCO₃ <b>above</b> expected upper bound → concurrent metabolic alkalosis`));
        }
      } else {
        steps.push(step(3,'amber',`<b>PaCO₂ ${pv.toFixed(1)} ≥ 35</b> → primary metabolic mechanism (bicarbonate excess)`));
        const comp=(pH>=ph1&&pH<=ph2)?'Compensated ':((pv>=35&&pv<=45)?'Uncompensated ':'Partially Compensated ');
        steps.push(step(4,'amber',`<b>${comp.trim()}</b>`));
        steps.push(step(5,'amber',`Met. alkalosis range → expected PaCO₂: ${mono(mlo.toFixed(1)+' – '+mhi.toFixed(1))} | Actual: ${mono(pv.toFixed(1))}`));
        if(pv>=mlo&&pv<=mhi){
          Diag=comp+'Simple Metabolic Alkalosis';
          steps.push(step(6,'blue','PaCO₂ within expected → <b>Simple</b>'));
        } else if(pv<mlo){
          Diag=comp+'Metabolic Alkalosis + Respiratory Alkalosis';
          steps.push(step(6,'blue','PaCO₂ <b>below</b> expected → superimposed respiratory alkalosis'));
        } else {
          Diag=comp+'Metabolic Alkalosis + Respiratory Acidosis';
          steps.push(step(6,'red','PaCO₂ <b>above</b> expected → superimposed respiratory acidosis'));
        }
      }
    }

    // AG check
    if(Diag.includes('Metabolic Acidosis')){
      if(AG<=12){
        AGdiag='Normal Anion Gap Acidosis (NAGA)';
        steps.push(step(steps.length+1,'green',`<b>AG = ${AG.toFixed(1)} ≤ 12</b> → Normal anion gap — consider hyperchloraemia, diarrhoea, RTA`));
      } else {
        if(HG>6){AGdiag='High AG + concurrent Metabolic Alkalosis'; steps.push(step(steps.length+1,'amber',`<b>AG = ${AG.toFixed(1)} > 12</b>, HG = ${HG.toFixed(1)} > 6 → HAGMA + metabolic alkalosis`));}
        else if(HG<-6){AGdiag='High AG + Normal AG Acidosis (mixed)'; steps.push(step(steps.length+1,'red',`<b>AG = ${AG.toFixed(1)} > 12</b>, HG = ${HG.toFixed(1)} < −6 → HAGMA + NAGA mixed`));}
        else {AGdiag='High Anion Gap Metabolic Acidosis (HAGMA)'; steps.push(step(steps.length+1,'red',`<b>AG = ${AG.toFixed(1)} > 12</b>, HG = ${HG.toFixed(1)} within −6–+6 → pure HAGMA`));}
      }
    }
  }

  // Update DOM
  const card=document.getElementById('diag-card');
  card.className='diag-card '+diagClass;
  const tag=document.getElementById('diag-tag');
  tag.className='diag-tag '+tagClass;
  tag.textContent=tagLabel;
  document.getElementById('diag-primary').textContent=Diag||'—';
  document.getElementById('diag-ag').innerHTML=AGdiag?`<span>Anion gap:</span> ${AGdiag}`:'';
  document.getElementById('step-list').innerHTML=steps.join('');

  // ── Show/hide UrC slider & prompt ──────────────────────
  const urcBlock=document.getElementById('urc-slider-block');
  const urcReq=document.getElementById('urc-required');
  const showUrC=(cco2&&pH>=7.4);
  urcBlock.style.display=showUrC?'block':'none';
  urcReq.classList.toggle('hidden',!needsUrC);
  // Update UrC slider display
  if(showUrC){
    const urcVal=g('sl-urc');
    const niUrc=document.getElementById('ni-urc');
    if(niUrc&&document.activeElement!==niUrc) niUrc.value=urcVal;
    if(niUrc) niUrc.className='num-input warn';
    const pctUrc=(urcVal/80*100).toFixed(1);
    const rfUrc=document.getElementById('rf-urc');
    if(rfUrc) rfUrc.style.cssText=`left:0;width:${pctUrc}%;background:${urcVal<20?'#de1738':'#017bb5'}`;
  }

  // ── SIG calculations ─────────────────────────────────
  const SIG = nav+Ca+Mg+K - (clv+lac) - (hv + alb*(0.123*pH-0.631) + po4*(0.309*pH-0.469));
  const BDE = -1*sbd - (nav-clv-38) + 0.25*(42-alb);

  document.getElementById('sig-k-val').textContent=K.toFixed(1);
  document.getElementById('sig-ca-val').textContent=Ca.toFixed(2);
  document.getElementById('sig-mg-val').textContent=Mg.toFixed(2);
  document.getElementById('sig-lac-val').textContent=lac.toFixed(1);
  document.getElementById('sig-po4-val').textContent=po4.toFixed(2);
  document.getElementById('sig-sbd-val').textContent=sbd.toFixed(1);

  document.getElementById('sig-val').textContent=SIG.toFixed(2);
  document.getElementById('bde-val').textContent=BDE.toFixed(2);

  const sigAbnormal=SIG>2;
  document.getElementById('sig-interp').textContent=sigAbnormal?'Abnormal — unmeasured anions present':'Normal (≤ 2 mmol/L)';
  document.getElementById('bde-interp').textContent=BDE>4?'Elevated — unmeasured anion load':BDE<0?'Negative — check albumin/chloride':'Within expected range';

  document.getElementById('sig-result-box').style.background=sigAbnormal?'#8b0f22':var_navy();
  document.getElementById('bde-result-box').style.background=BDE>4?'#854F0B':'#017bb5';

  const sigSteps=[];
  sigSteps.push(step(1,'gray',`<b>Albumin charge contribution:</b> ${mono(alb)} × (0.123 × ${mono(pH.toFixed(2))} − 0.631) = ${mono((alb*(0.123*pH-0.631)).toFixed(2))}`));
  sigSteps.push(step(2,'gray',`<b>Phosphate charge contribution:</b> ${mono(po4)} × (0.309 × ${mono(pH.toFixed(2))} − 0.469) = ${mono((po4*(0.309*pH-0.469)).toFixed(2))}`));
  sigSteps.push(step(3,sigAbnormal?'red':'green',`<b>SIG = ${SIG.toFixed(2)} mmol/L</b> ${sigAbnormal?'— unmeasured strong anions present (ketones, toxins, uraemia)':'— no significant unmeasured anion burden'}`));
  sigSteps.push(step(4,'blue',`<b>BDE gap = ${BDE.toFixed(2)}:</b> reflects unmeasured ion contribution to base deficit, corrected for Na/Cl ratio and hypoalbuminaemia`));
  if(sigAbnormal&&BDE>4) sigSteps.push(step(5,'amber','<b>Both SIG and BDE elevated</b> — consider ketoacidosis, toxic alcohol, severe renal failure'));
  document.getElementById('sig-steps').innerHTML=sigSteps.join('');
}

