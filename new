// ── Shared diagnosis engine (pure function, no DOM) ──────────
function runDiagnosis(r){
  const pH=+r.pH, pv=+r.paCO2||+r.pco2||+r.PaCO2||0;
  const hv=+r.HCO3||+r.hco3||0;
  const nav=+r.Na||+r.na||0, clv=+r.Cl||+r.cl||0, alb=+r.albumin||+r.Albumin||0;
  const urc=+r.UrCl||+r.urCl||+r.ur_cl||0;
  const cco2=!!(r.CCO2||r.cco2||r.chronic_co2);
  const exac=!!(r.Exac||r.exac);
  if(!pH||!pv||!hv) return {diag:'Incomplete Data',ag:'',cls:'neutral',steps:[]};
  const ph1=7.3,ph2=7.5,p2=45;
  let Diag='',AGdiag='',steps=[];
  const AG=(nav&&clv&&alb)?nav-(clv+hv)+0.25*(44-alb):null;
  const HG=(nav&&clv)?nav-clv-36:null;
  const agsuf=()=>{if(AG===null)return'';if(AG<=12)return'Normal Anion Gap Acidosis (NAGA)';if(HG>6)return'High AG + Met. Alkalosis';if(HG<-6)return'High AG + Normal AG Acidosis';return'High Anion Gap Metabolic Acidosis (HAGMA)';};
  const pHc=6.1+Math.log10(hv/(0.03*pv));
  const diff=Math.abs(pHc-pH);
  steps.push({c:'gray',t:`pH check: calc = ${pHc.toFixed(2)}, diff = ${diff.toFixed(2)}${diff>0.1?' — INCONSISTENT':' ✓'}`});
  if(cco2){
    if(pH<7.3&&pv<=57&&hv<24&&!exac){ Diag='Chronic Respiratory Acidosis + Metabolic Acidosis'; steps.push({c:'red',t:'CCO2: pH<7.3, PaCO2≤57, HCO3<24, no exac'}); }
    else if(pH<7.3&&pv>2*hv-8&&hv>=30&&exac){ Diag='Acute on Top of Chronic Respiratory Acidosis'; steps.push({c:'red',t:'Acute-on-chronic criteria met'}); }
    else if(pH<7.3&&pv>57&&hv<24&&exac){ Diag='Acute on Chronic Respiratory Acidosis + Metabolic Acidosis'; steps.push({c:'red',t:'Acute-on-chronic + met. acidosis'}); }
    else if(pH>=7.4){
      const thresh=0.92*(2*hv-8);
      if(!urc){ Diag='Chronic Resp. Acidosis + Met. Alkalosis (Ur.Cl required)'; steps.push({c:'amber',t:'Urinary chloride not provided — subtype unknown'}); }
      else if(pv<=thresh){ Diag=urc<20?'...Metabolic Alkalosis (Post-Hypercapnic)':'...Metabolic Alkalosis (Mixed)'; steps.push({c:'blue',t:`PaCO2≤thresh(${thresh.toFixed(1)}), Ur.Cl=${urc}`}); }
      else { Diag=urc>=20?'...Met. Alkalosis (Independent, Cl-Resistant / Diuresis)':'...Met. Alkalosis (Independent, Cl-Responsive)'; steps.push({c:'blue',t:`PaCO2>thresh, Ur.Cl=${urc}`}); }
    }
  }
  if(!Diag){
    if(pH>=7.35&&pH<=7.45&&pv>=35&&pv<=45&&hv>=22&&hv<=28){ Diag='Normal ABG — Check Anion Gap'; steps.push({c:'green',t:'All within normal range'}); }
    else if(pH<7.4){
      steps.push({c:'red',t:`pH ${pH.toFixed(2)} < 7.4 → acidaemia`});
      if(pv>=p2){
        const acute=(pH<ph1||pH>ph2),mult=acute?1:4;
        const eq=22-((40-pv)/10)*mult,eq1=28-((40-pv)/10)*mult;
        steps.push({c:'amber',t:`PaCO2 ${pv.toFixed(1)} ≥ 45, ${acute?'acute':'chronic'}, expected HCO3: ${eq.toFixed(1)}–${eq1.toFixed(1)}, actual: ${hv.toFixed(1)}`});
        if(hv>eq&&hv<eq1) Diag=`Simple ${acute?'Acute':'Chronic'} Respiratory Acidosis`;
        else if(hv<=eq)   Diag=`${acute?'Acute':'Chronic'} Respiratory Acidosis + Metabolic Acidosis`;
        else              Diag=`${acute?'Acute':'Chronic'} Respiratory Acidosis + Metabolic Alkalosis`;
      } else {
        const comp=(pH>=ph1&&pH<=ph2)?'Compensated ':((pv>=35&&pv<=45)?'Uncompensated ':'Partially Compensated ');
        const wlo=0.9*(1.5*hv+4),whi=1.1*(1.5*hv+12);
        steps.push({c:'amber',t:`PaCO2 ${pv.toFixed(1)} < 45, ${comp.trim()}, Winters': ${wlo.toFixed(1)}–${whi.toFixed(1)}, actual: ${pv.toFixed(1)}`});
        if(pv>=wlo&&pv<=whi) Diag=comp+'Simple Metabolic Acidosis';
        else if(pv<wlo)      Diag=comp+'Metabolic Acidosis + Respiratory Alkalosis';
        else                 Diag=comp+'Metabolic Acidosis + Respiratory Acidosis';
      }
    } else {
      steps.push({c:'blue',t:`pH ${pH.toFixed(2)} ≥ 7.4 → alkalaemia`});
      if(pv<35){
        const acute=(pH>ph2),mult=acute?2:5;
        const eq=22-((40-pv)/10)*mult,eq1=28-((40-pv)/10)*mult;
        steps.push({c:'amber',t:`PaCO2 ${pv.toFixed(1)} < 35, ${acute?'acute':'chronic'}, expected HCO3: ${eq.toFixed(1)}–${eq1.toFixed(1)}, actual: ${hv.toFixed(1)}`});
        if(hv>eq&&hv<eq1) Diag=`Simple ${acute?'Acute':'Chronic'} Respiratory Alkalosis`;
        else if(hv<=eq)   Diag=`${acute?'Acute':'Chronic'} Respiratory Alkalosis + Metabolic Acidosis`;
        else              Diag=`${acute?'Acute':'Chronic'} Respiratory Alkalosis + Metabolic Alkalosis`;
      } else {
        const comp=(pH>=ph1&&pH<=ph2)?'Compensated ':((pv>=35&&pv<=45)?'Uncompensated ':'Partially Compensated ');
        const mlo=0.9*(0.7*hv+15),mhi=1.1*(0.7*hv+15);
        steps.push({c:'amber',t:`PaCO2 ${pv.toFixed(1)} ≥ 35, ${comp.trim()}, met.alk range: ${mlo.toFixed(1)}–${mhi.toFixed(1)}`});
        if(pv>=mlo&&pv<=mhi) Diag=comp+'Simple Metabolic Alkalosis';
        else if(pv<mlo)      Diag=comp+'Metabolic Alkalosis + Respiratory Alkalosis';
        else                 Diag=comp+'Metabolic Alkalosis + Respiratory Acidosis';
      }
    }
    if(AG!==null&&Diag.includes('Metabolic Acidosis')){ AGdiag=agsuf(); steps.push({c:'green',t:`AG = ${AG.toFixed(1)} → ${AGdiag}`}); }
  }
  const cls=Diag.includes('Acidosis')?'acidosis':Diag.includes('Alkalosis')?'alkalosis':Diag.includes('Normal')?'normal':'neutral';
  return {diag:Diag,ag:AGdiag,cls,steps,pH,pv,hv,nav,clv,alb,AG,diff};
}

