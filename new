    const inTiles=Object.entries(inMap).filter(([,v])=>v&&!isNaN(v)).map(([k,v])=>`<div class="batch-inp-tile"><div class="batch-inp-lbl">${k}</div><div class="batch-inp-val">${parseFloat(v).toFixed(2).replace(/\.?0+$/,'')}</div></div>`).join('');
    const stepHtml=res.steps.map((s,si)=>`<li class="batch-step"><div class="batch-step-dot" style="background:${dotBg[s.c]||dotBg.gray};color:${dotColors[s.c]||dotColors.gray}">${si+1}</div><span style="color:var(--text)">${s.t}</span></li>`).join('');
